<Window x:Class="XSPSX.SystemUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Update" WindowState="Maximized" WindowStyle="None" 
        Background="Black" Height="1080" Width="1920" KeyDown="Window_KeyDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0" Duration="0:0:0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <Style x:Key="PS3ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#11FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderBrush" Value="Cyan"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Cyan" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <MediaElement x:Name="WaveBackground" Source="Resources/xmbWave.mp4" 
                      LoadedBehavior="Manual" Stretch="Fill" MediaEnded="WaveBackground_MediaEnded" />

        <Border Background="#66000000"/>

        <Grid Margin="150,0,150,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,100,0,0">
                <TextBlock Text="System Update" Foreground="White" FontSize="42" FontFamily="Segoe UI Light" />
                <Rectangle Height="1" Fill="White" HorizontalAlignment="Stretch" Margin="0,15,0,0" Opacity="0.4"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid x:Name="ConfirmationPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="450"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,50,0">
                        <TextBlock x:Name="UpdateStatusHeader" Text="Checking for update data..." Foreground="White" FontSize="32" Margin="0,0,0,10"/>
                        <TextBlock x:Name="UpdateFileName" Text="Searching storage media..." Foreground="Cyan" FontSize="20" Opacity="0.6" FontFamily="Consolas"/>
                        <TextBlock Text="Do you want to begin the installation process? During the update, do not turn off the system or remove the storage media." 
                                   Foreground="#BBB" FontSize="18" TextWrapping="Wrap" Margin="0,30,0,0" LineHeight="28"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button x:Name="UpdateBtn" Content="Update" Click="StartUpdate_Click" 
                                Style="{StaticResource PS3ButtonStyle}" Margin="0,10" Height="75" FontSize="26"/>
                        <Button x:Name="CancelBtn" Content="Cancel" Click="CancelUpdate_Click" 
                                Style="{StaticResource PS3ButtonStyle}" Margin="0,10" Height="75" FontSize="26"/>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="InstallPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Installing..." Foreground="White" FontSize="24" Margin="0,0,0,40" HorizontalAlignment="Center" Opacity="0.9"/>
                    <Grid Width="1000" Height="4" Background="#33FFFFFF">
                        <ProgressBar x:Name="UpdateProgressBar" Minimum="0" Maximum="100" Value="0" Background="Transparent" Foreground="White" BorderThickness="0">
                            <ProgressBar.Effect>
                                <DropShadowEffect Color="White" BlurRadius="15" ShadowDepth="0" Opacity="0.7"/>
                            </ProgressBar.Effect>
                        </ProgressBar>
                    </Grid>
                    <TextBlock x:Name="PercentageText" Text="0%" Foreground="White" FontSize="48" Margin="0,30,0,0" HorizontalAlignment="Center" FontFamily="Segoe UI Semilight"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Margin="0,0,0,100">
                <Rectangle Height="1" Fill="White" HorizontalAlignment="Stretch" Margin="0,0,0,15" Opacity="0.4"/>
                <Grid>
                    <TextBlock Text="A / ENTER : Confirm   |   B / ESC : Back" Foreground="White" FontSize="18" Opacity="0.5" HorizontalAlignment="Left"/>
                    <TextBlock Text="XSPSX System Software Simulation" Foreground="White" FontSize="18" Opacity="0.5" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>

        <Border x:Name="ExploitOverlay" Visibility="Collapsed" 
                Background="#CC0A0A0A" BorderBrush="#4400FFFF" BorderThickness="1" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Width="600" Height="450" Margin="40">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#4400FFFF">
                    <TextBlock Text="DEBUG: KERNEL_SVC_LOADER" Foreground="Cyan" FontSize="12" Margin="10,5" FontWeight="Bold"/>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="LogScroller" VerticalScrollBarVisibility="Hidden">
                    <TextBlock x:Name="KernelLogs" Foreground="#00FF99" FontFamily="Consolas" FontSize="14" Margin="15" TextWrapping="Wrap" LineHeight="20"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>