<Window x:Class="XSPSX.SystemInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Information" WindowState="Maximized" WindowStyle="None" 
        Background="Black" Height="1080" Width="1920" KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="PS3ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#11FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderBrush" Value="Cyan"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontFamily" Value="Segoe UI Light"/>
            <Setter Property="Margin" Value="0,10,50,10"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <MediaElement x:Name="WaveBackground" Source="Resources/xmbWave.mp4" 
                      LoadedBehavior="Manual" Stretch="Fill" MediaEnded="WaveBackground_MediaEnded" />

        <Border Background="#CC000000"/>

        <Grid Margin="150,100,150,100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="System Information" Foreground="White" FontSize="42" FontFamily="Segoe UI Light" />
                <Rectangle Height="1" Fill="White" HorizontalAlignment="Stretch" Margin="0,15,0,0" Opacity="0.4"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="0,50,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="System Software" Style="{StaticResource InfoLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FirmwareDisplay" Text="4.90" Style="{StaticResource InfoValue}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Exploit Status" Style="{StaticResource InfoLabel}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="JailbreakStatus" Text="Disabled" Style="{StaticResource InfoValue}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Kernel Version" Style="{StaticResource InfoLabel}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="0.1.25-LVK2-PRE" Style="{StaticResource InfoValue}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Syscalls (LV2)" Style="{StaticResource InfoLabel}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SyscallStatus" Text="Restricted" Style="{StaticResource InfoValue}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Homebrew Environment" Style="{StaticResource InfoLabel}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="HomebrewStatus" Text="Locked" Style="{StaticResource InfoValue}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="MAC Address" Style="{StaticResource InfoLabel}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="00:1A:4D:5E:21:0B" Style="{StaticResource InfoValue}"/>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2">
                <Rectangle Height="1" Fill="White" HorizontalAlignment="Stretch" Margin="0,0,0,15" Opacity="0.4"/>
                <Grid>
                    <TextBlock Text="B / ESC : Back" Foreground="White" FontSize="18" Opacity="0.5" VerticalAlignment="Center"/>
                    <Button x:Name="BackBtn" Content="Back" Click="Back_Click" 
                            Style="{StaticResource PS3ButtonStyle}" HorizontalAlignment="Right" 
                            Width="200" Height="60" FontSize="20"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>