<Window x:Class="XSPSX.WebBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="XSPSX Web Browser" WindowState="Maximized" WindowStyle="None"
        Background="Transparent">

    <Grid>
        <!-- Background (XMB Waves Visible) -->
        <MediaElement Name="WaveBackground" Source="Resources/xmbWave.mp4" LoadedBehavior="Play" Stretch="Fill" />

        <!-- Top Bar -->
        <Border Background="Black" Height="50" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBox Name="UrlTextBox" Width="900" Height="30" FontSize="16" Background="Black" Foreground="White" BorderBrush="Gray"
                         KeyDown="UrlTextBox_KeyDown"/>
                <Button Name="GoButton" Content="🔍" Width="50" Height="30" Click="GoButton_Click"/>
                <Button Name="CloseButton" Content="✖" Width="50" Height="30" Background="Red" Foreground="White"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Web Browser -->
        <wv2:WebView2 Name="WebView" Margin="0,50,0,50"/>

        <!-- Bottom Bar (PS4-style) -->
        <Border Background="Black" Height="50" VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="❌ Enter | ⭕ Back | ⏹ Full Screen | 🔍 Search | ✖ Close" 
                           FontSize="16" Foreground="White" Margin="10"/>
            </StackPanel>
        </Border>

        <!-- Notification Popup -->
        <Border Name="NotificationGrid" Background="Black" Width="400" Height="100" CornerRadius="5" 
                Visibility="Collapsed" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,80">
            <StackPanel Orientation="Horizontal">
                <Image Name="NotificationIcon" Width="40" Height="40" Margin="10"/>
                <StackPanel>
                    <TextBlock Name="NotificationTitle" FontSize="14" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Name="NotificationMessage" FontSize="12" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
