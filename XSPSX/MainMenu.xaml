<Window x:Class="XSPSX.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XSPSX Main Menu" WindowState="Maximized" WindowStyle="None" Background="Black" Height="714" Width="1612" 
        KeyDown="Window_KeyDown" Loaded="Window_Loaded">

    <!-- Define Styles and Resources -->
    <Window.Resources>
        <!-- Style for Category Buttons -->
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Width" Value="150" />
            <Setter Property="Height" Value="150" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Icon -->
                            <Image Source="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Width="80" Height="80" />
                            <!-- Text -->
                            <TextBlock Text="{TemplateBinding Content}" FontSize="16" Foreground="White" Margin="5,10,5,0" TextAlignment="Center" />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background Wave Video -->
        <MediaElement Name="WaveBackground" 
                      Source="Resources/xmbWave.mp4" 
                      LoadedBehavior="Manual" 
                      Stretch="Fill" 
                      MediaEnded="WaveBackground_MediaEnded" />

        <!-- Game Background (Initially Hidden) -->
        <Image Name="GameBackground"
       Source="Resources/Icons/GameBackground.png"
       Stretch="UniformToFill"
       Opacity="0"
       HorizontalAlignment="Center"
       VerticalAlignment="Center"
       RenderTransformOrigin="0.5, 0.5">
            <Image.RenderTransform>
                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
            </Image.RenderTransform>
        </Image>


        <!-- Logo in Top-Left Corner -->
        <Image Source="Resources/xspsxBootLogo.png" 
               HorizontalAlignment="Left" 
               VerticalAlignment="Top" 
               Margin="40,20,0,0" 
               Width="500" 
               Height="150" />

        <!-- Horizontal Navigation Bar (Categories) -->
        <ScrollViewer Name="CategoryScrollViewer" 
                      HorizontalScrollBarVisibility="Hidden" 
                      VerticalScrollBarVisibility="Disabled" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center" 
                      Margin="0,0,0,400">
            <StackPanel Name="HorizontalStackPanel" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                <!-- Buttons will be dynamically added here -->
            </StackPanel>
        </ScrollViewer>

        <!-- Secondary Stack (Above Horizontal Categories) -->
        <ScrollViewer Name="SecondaryScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Height="170"
                      IsHitTestVisible="False" Width="556">
            <!-- Disable mouse interaction -->
            <StackPanel Name="SecondaryVerticalStackPanel"
                        Orientation="Vertical"
                        RenderTransformOrigin="0.5,0.5"
                        IsHitTestVisible="False" Width="448" Height="166">
                <!-- Disable mouse interaction -->
            </StackPanel>
        </ScrollViewer>

        <!-- Primary Stack (Below Horizontal Categories) -->
        <ScrollViewer Name="PrimaryScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Height="437"
                      Margin="0,392,0,0"
                      IsHitTestVisible="False" Width="556">
            <!-- Disable mouse interaction -->
            <StackPanel Name="PrimaryVerticalStackPanel"
                        Orientation="Vertical"
                        RenderTransformOrigin="0.5,0.5"
                        IsHitTestVisible="False" Width="462">
                <!-- Disable mouse interaction -->
            </StackPanel>
        </ScrollViewer>

        <!-- Game Side Menu -->
        <Grid Name="GameSideMenu" HorizontalAlignment="Right" VerticalAlignment="Center" Height="1050" Width="420" Visibility="Collapsed" Margin="0,0,50,0">
            <Border Background="#222" CornerRadius="10" BorderBrush="Cyan" BorderThickness="2">
                <StackPanel>
                    <!-- Title -->
                    <TextBlock Text="Game Library" FontSize="20" FontWeight="Bold" Foreground="White" Margin="10" HorizontalAlignment="Center" />

                    <!-- Separator -->
                    <Border Background="Cyan" Height="2" Margin="10" />

                    <!-- Game List -->
                    <ListBox Name="GameListBox"
         Background="Transparent"
         BorderThickness="0"
         Foreground="White"
         FontSize="16"
         VerticalAlignment="Stretch"
         HorizontalContentAlignment="Center"
         VerticalContentAlignment="Center"
         SelectionChanged="GameListBox_SelectionChanged">
                        <ListBoxItem Content="Kingdom Hearts 2 Final Mix" Tag="C:\PCSX2\games\Kingdom Hearts 2 Final Mix.iso" />
                        <ListBoxItem Content="Final Fantasy X" Tag="C:\PCSX2\games\Final Fantasy X.iso" />
                        <ListBoxItem Content="Shadow of the Colossus" Tag="C:\PCSX2\games\Shadow of the Colossus.iso" />
                        <ListBoxItem Content="Close" Tag="Close" />
                    </ListBox>



                </StackPanel>
            </Border>
        </Grid>



        <!-- Notification Area -->
        <Grid Name="NotificationGrid" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0" Visibility="Collapsed">
            <Border Background="Black" CornerRadius="1" Padding="0" Width="370" Height="120" BorderBrush="White" BorderThickness="2">
                <StackPanel Orientation="Horizontal">
                    <!-- Icon on the Left -->
                    <Image Name="NotificationIcon" Width="50" Height="50" Margin="10,0,20,0" VerticalAlignment="Center" />

                    <!-- Text Content -->
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Stretch" Width="250">
                        <!-- Title -->
                        <TextBlock Name="NotificationTitle" Text="Notification" FontSize="16" Foreground="White" FontWeight="Bold" TextAlignment="Left" />

                        <!-- Cyan Separator Line -->
                        <Border Background="Cyan" Height="2" Margin="0,5,0,5" HorizontalAlignment="Stretch" />

                        <!-- Message -->
                        <TextBlock Name="NotificationMessage" Text="Message" FontSize="14" Foreground="White" TextAlignment="Left" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

